@startuml C1_Альтернативное_Решение_Свиноводство

!include ../C4_Context.puml

title Контекстная диаграмма системы мониторинга свиноводства - Альтернативное решение (исправленное)

Person(operator, "Оператор фермы", "Контролирует состояние животных и оборудования")
Person(manager, "Менеджер", "Анализирует показатели и принимает решения")
Person(vet, "Ветеринар", "Отслеживает здоровье поголовья")
Person(technician, "Техник", "Обслуживает оборудование")

System(pig_edge, "Edge-система фермы", "Полностью автономная обработка видео и управление")
System(pig_cloud, "Облачная платформа", "Централизованная аналитика и управление")

' Внутренние системы АгроТех для интеграции
System(existing_kafka, "Apache Kafka АгроТех", "Корпоративная шина для интеграции")
System(existing_erp, "1С:Агро", "ERP система АгроТех")
System(existing_dwh, "ClickHouse АгроТех", "Корпоративное DWH")
System(existing_bi, "Power BI АгроТех", "Корпоративная BI")

' Внешние системы
System_Ext(saas_monitoring, "SaaS мониторинг инфраструктуры", "Datadog/Prometheus Cloud")
System_Ext(ml_cloud, "ML Cloud Service", "AWS SageMaker / Google Vertex AI")
System_Ext(iot_devices, "IoT оборудование", "Камеры, датчики, контроллеры")
System_Ext(mobile_app_new, "Мобильное приложение", "Специализированное приложение")
System_Ext(notification_gateway, "Облачный сервис уведомлений", "AWS SNS / Twilio")
System_Ext(message_queue, "Облачная очередь сообщений", "AWS SQS / RabbitMQ Cloud")

' Взаимодействия пользователей
Rel(operator, pig_edge, "Локальный мониторинг и управление")
Rel(operator, mobile_app_new, "Мобильный доступ")
Rel(manager, pig_cloud, "Централизованная аналитика")
Rel(vet, pig_cloud, "Анализ здоровья поголовья")
Rel(technician, pig_edge, "Диагностика оборудования")

' Асинхронные взаимодействия Edge-Cloud
Rel(pig_edge, message_queue, "Публикация событий", "AMQP/MQTT")
Rel(message_queue, pig_cloud, "Асинхронная обработка", "Pull-based")
Rel(pig_edge, pig_cloud, "Периодическая синхронизация", "REST API с экспоненциальным backoff")

' Интеграция с корпоративными системами
Rel(pig_cloud, existing_kafka, "Публикация событий для АгроТех", "Kafka Protocol")
Rel(pig_cloud, existing_erp, "Синхронизация данных", "REST API")
Rel(pig_cloud, existing_dwh, "Экспорт аналитики", "ETL")
Rel(existing_bi, existing_dwh, "Читает данные", "SQL")

' Внешние интеграции
Rel(pig_cloud, saas_monitoring, "Мониторинг инфраструктуры", "API")
Rel(pig_cloud, ml_cloud, "Обучение моделей", "REST API")
Rel(pig_edge, ml_cloud, "Загрузка обученных моделей", "Offline sync")
Rel(iot_devices, pig_edge, "Локальный сбор данных", "MQTT/Modbus")
Rel(mobile_app_new, pig_edge, "Прямой доступ без интернета", "Local WiFi")
Rel(mobile_app_new, pig_cloud, "Облачный доступ", "REST API")
Rel(pig_edge, notification_gateway, "Критические уведомления", "Queue + API")
Rel(pig_cloud, notification_gateway, "Управление уведомлениями", "REST API")

' Примечание о характеристиках
note right of pig_edge
  Edge характеристики:
  - Обработка 20+ HD видеопотоков локально
  - ML-инференс < 100мс на кадр
  - Локальные алерты < 5 сек
  - Полная автономность 72+ часов
  - Асинхронная синхронизация
  - Устойчивость к сбоям связи
end note

note left of message_queue
  Асинхронная интеграция:
  - Гарантированная доставка
  - Retry с backoff
  - Dead letter queue
  - Батчинг сообщений
end note

@enduml